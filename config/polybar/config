[colors]
background = #2e3436
background-alt = #373b41
foreground = #dfdfdf
foreground-alt = #555
primary = #ffb52a
secondary = #e60053
alert = #bd2c40
green = #4be349
disabled = #5d40ad
red = #ff0000
purple = #8000ff

include-file = ~/.config/polybar/colors

[bar/parrot]
width = 16%
height = 4%
offset-x = 1%
offset-y = 1.5%
radius = 8
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

font-0 = Cantarell:size=11
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = FontAwesome:size=10

modules-left =
modules-center = memory cpu fecha
modules-right = 

scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

separator = "|"

[bar/right]
width = 12%
height = 4%
offset-x = 87.5%.
offset-y = 1.5%
radius = 8
fixed-center = true

background = ${colors.background}
foreground = ${colors.foreground}

;line-size = 1
;line-color = #f00

border-size = 0
border-color = #00000000

padding-left = 5
padding-right = 5

font-0 = Cantarell:size=11
font-1 = unifont:fontformat=truetype:size=8:antialias=false;0
font-2 = FontAwesome:size=10
font-3 = Symbols Nerd Font:style=Regular 

modules-left = 
modules-center = hora powermenu
modules-right =

tray-position = right
tray-padding = 2

scroll-up = i3wm-wsnext
scroll-down = i3wm-wsprev

cursor-click = pointer
separator = "|"

[bar/ventana] 
font-0 = Hack Nerd Font Propo:style=Regular
font-1= Symbols Nerd Font:style=Regular 

background = ${colors.background}
foreground = ${colors.foreground}

width = 24.0%
height = 4%
offset-x = 47.5%
offset-y = 1.5%
radius = 8

line-size = 3

;modules-left =
modules-center = xworkspaces
;modules-right =

[bar/red]
width = 14.5%
height = 4%
offset-x = 17.5%
offset-y = 1.5%
radius = 8

font-0 = Hack Nerd Font Propo:style=Regular
font-1= Symbols Nerd Font:style=Regular 

background = ${colors.background}

modules-center = eth

[bar/htb]
width = 14.5%
height = 4%
offset-x = 32.5%
offset-y = 1.5%
radius = 8

font-0 = Hack Nerd Font Propo:style=Regular
font-1= Symbols Nerd Font:style=Regular 

background = ${colors.background}

modules-center = wlan

[bar/target]
width = 14.5%
height = 4%
offset-x = 72.5%
offset-y = 1.5%
radius = 8

font-0 = Hack Nerd Font Propo:style=Regular
font-1= Symbols Nerd Font:style=Regular 

background = ${colors.background}

modules-center = targeta

[module/xworkspaces]
type = internal/xworkspaces

label-active = Ôáź
label-active-background = ${colors.background-alt}
label-active-foreground = ${colors.red}
label-active-underline = ${colors.primary}
label-active-padding= 1

label-occupied = Óôü
label-occupied-foreground = ${color.prshade7}
label-occupied-padding = 1

label-urgent = %name%
label-urgent-background = ${colors.alert}
label-urgent-padding = 1

label-empty = ůįĮČ
label-empty-foreground = ${color.lbshade8}
label-empty-padding = 1

[module/cpu]
type = internal/cpu
interval = 2

format-prefix = ÔÉ§
format-prefix-foreground = ${colors.foreground-alt}
format-prefix-padding-top = 2

label = %percentage:2%%
label-padding = 2

[module/memory]
type = internal/memory
interval = 2

format-prefix =  Ôāģ 
format-prefix-foreground = ${colors.green}
format-prefix-padding-left = 2

label = %percentage_used%%
label-padding = 2

[module/wlan]
type = custom/script
interval = 5

format-prefix = ůįĚī
format-prefix-foreground = ${color.light-green}
format-prefix-padding = 1
exec = ~/.config/bin/htb.sh

[module/eth]
type = custom/script
interval = 5

format-prefix = ůĪėÜ
format-prefix-padding = 1
format-prefix-foreground = ${colors.primary}
exec = ~/.config/bin/net.sh

[module/targeta]
type = custom/script
interval = 5

format-prefix = ůįīĽ
format-prefix-padding = 1
format-prefix-foreground = ${color.lime}
exec = ~/.config/bin/target.sh

[module/hora]
type = internal/date
internval = 5

time = %H:%M

label = %time%
label-foreground = ${colors.primary}
label-padding = 2

[module/fecha]
type = internal/date
interval = 5

date = %d-%m-%Y
;time = %H:%M

label = %date%
label-foreground = ${colors.primary}
label-padding = 2

[module/pulseaudio]
type = internal/pulseaudio

format-volume = <label-volume> 
label-volume = ÔÄ®  %percentage%%
label-muted = ÔÄ¶ mute
label-muted-foreground = #666

[module/alsa]
type = internal/alsa

format-volume = <label-volume>
label-volume = ÔÄ® %percentage%%
label-volume-foreground = ${root.foreground}

format-muted-foreground = ${colors.foreground-alt}
label-muted = ÔÄ¶ mute

[module/battery]
type = internal/battery
battery = BAT0
adapter = AC
full-at = 100

format-charging = <animation-charging> <label-charging>

format-discharging = <label-discharging>
animation-charging-0 = ÔČÉ
animation-charging-1 = ÔČā
animation-charging-2 = ÔČĀ
animation-charging-3 = %{F#4be349} ÔČÄ
animation-charging-framerate = 750

animation-discharging-0 = ÔČÄ
animation-discharging-1 = ÔČĀ
animation-discharging-2 = ÔČā
animation-discharging-3 = ÔČÉ
animation-discharging-4 = ÔČĄ
animation-discharging-framerate = 750
label-charging = %percentage% %
label-discharging = ÔČā %percentage% %
label-full = %{F#4be349}ÔČÄ %percentage% %

[module/powermenu]
type = custom/menu

format-spacing = 1

label-open = ůįćú
label-open-foreground = ${colors.secondary}
label-open-padding = 2

label-close = ůįćú
label-close-foreground = ${colors.foreground-alt}
label-close-padding = 1

label-separator = |
;label-separator-foreground = ${colors.foreground-alt}

menu-0-0 = ůįĎď
menu-0-0-foreground = ${color.blue}
menu-0-0-exec = systemctl reboot

menu-0-1 =  ÔĒĎ
menu-0-1-foreground = ${color.red}
menu-0-1-exec = dm-tool lock

menu-0-2 =  ůįí≤
menu-0-2-foreground = ${color.red}
menu-0-2-exec = systemctl poweroff


[setting]
screenchange-reload = true
pseudo-transparency = true
